{
  "manifest_version": 3,
  "name": "Firechrone",
  "version": "0.1.0",
  "description": "Bring compatible Chrome extensions to Firefox with automatic analysis and conversion.",

  "author": "foxsign",

  "host_permissions": [
    "https://chromewebstore.google.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://chromewebstore.google.com/*"
      ],
      "js": [
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}